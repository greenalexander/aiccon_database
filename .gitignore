# ── Credentials and environment ──────────────────────────────────────────────
.env
*.env
 
# ── Manual source data (raw downloads — never commit) ────────────────────────
ingestion/manual_sources/**/*
!**/ .gitkeep 

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.Python
*.egg-info/
dist/
build/
.eggs/
 
# ── Virtual environments ──────────────────────────────────────────────────────
.venv/
venv/
env/
 
# ── DuckDB files (built artefacts — regenerated by pipeline) ─────────────────
*.duckdb
*.duckdb.wal
# gitignored because it's a build artefact — regenerated by the pipeline from the 
# parquet files on SharePoint. Never needed in version control. 
# The parquet files themselves aren't in git either (they live on SharePoint)
 
# ── OS and editor noise ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
 
# ── Jupyter (if used for exploration) ────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb
 
# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/