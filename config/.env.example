# aiccon-data environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and must never be committed.

# ── SharePoint synced folder ──────────────────────────────────────────────────
# Full path to the root of your SharePoint/OneDrive synced folder.
# Windows example:  C:/Users/yourname/OneDrive - AICCON/
# macOS example:    /Users/yourname/Library/CloudStorage/OneDrive-AICCON/
SHAREPOINT_ROOT=
